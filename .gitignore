# Built image artifacts (large binaries, not for git)
output/*.qcow2

# Packer cache
packer/.packer.d/
packer/packer_cache/

# Node dependencies (bats installed locally for harness tests; no root package.json)
node_modules/

# plugin/cli/ TypeScript build output + test-build tree (tsc emits, not checked in)
plugin/cli/dist/
plugin/cli/dist-test/

# Phase 6: release build output (scripts/build-release.sh produces tarball + sha256 + catalog snapshot + optional .deb here)
dist/

# Phase 6 Plan 06-03: tests/qemu/boot.sh writes serial.log here on failure for CI upload-artifact
tests/qemu/artifacts/
tests/qemu/cache/

# Phase 6 Plan 06-04: repo-root install.sh is CI-generated by .github/workflows/deploy.yml
# from packaging/curl-installer/install.sh at Pages build time (Pattern 5 — Pitfall 7
# anti-drift: exactly one editable source under packaging/).
# Pattern anchored to repo root with a leading slash — without it, the gh-pages
# branch deploy (and pr-preview deploys) would also gitignore the served
# install.sh under /pr-preview/pr-N/install.sh and the canonical
# `curl https://agentlinux.org/install.sh | sudo bash` URL would 404.
/install.sh

# v0.4.0 Phase 9 (CLEAN-03): hardening for public-repo posture.

# Local environment / credential artifacts — never committed.
# Defence in depth: SEC-05 gitleaks gate also blocks any accidental staging,
# and SEC-03 audit verified none exist in history.
# `.env.local.example` is the committed test-secret template (commented
# placeholders only). The negation must come after `.env.*` on its own line —
# gitignore does not support inline comments on rule lines.
.env
.env.*
!.env.example
!.env.local.example
.npmrc
!plugin/cli/.npmrc
.git-credentials
.netrc
*.pem
*.key
!plugin/catalog/**/*.key.json
*.crt
id_rsa
id_dsa
id_ed25519
id_ed25519_*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.iml

# Coverage + test output
coverage/
.nyc_output/
*.lcov
.pytest_cache/
.ruff_cache/
.mypy_cache/

# TypeScript build cache
*.tsbuildinfo

# Python (in case any contributor lands a script that needs it)
__pycache__/
*.pyc
*.pyo

# pnpm / yarn local store
.pnpm-store/
.yarn/cache/
.yarn/install-state.gz
