{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Advisory in v0.3.0. Promotion to gate is a v0.4 decision (see ADR-007 follow-up).",
  "packageManager": "npm",
  "reporters": ["html", "progress", "clear-text"],
  "testRunner": "command",
  "commandRunner": {
    "command": "npm test"
  },
  "mutate": ["src/**/*.ts", "!src/**/*.test.ts"],
  "coverageAnalysis": "perTest",
  "thresholds": { "high": 85, "low": 60, "break": 0 },
  "timeoutMS": 30000,
  "concurrency": 2
}
