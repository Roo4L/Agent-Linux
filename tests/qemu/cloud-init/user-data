#cloud-config
# Phase 6 Plan 06-03: minimal cloud-init seed for the AgentLinux QEMU harness.
# Injects a per-run SSH pubkey into root; enables sshd; installs bats + jq
# so the in-guest bats suite can run. No agent pre-installation here — the
# AgentLinux installer runs over SSH AFTER cloud-init finishes.
#
# Placeholder __AGENTLINUX_QEMU_PUBKEY__ is sed-replaced per-run by
# tests/qemu/boot.sh; the rendered file is fed to cloud-localds(1).
# This file is the template — keep it committed with the placeholder intact.
ssh_pwauth: false
disable_root: false
users:
  - name: root
    ssh_authorized_keys:
      - __AGENTLINUX_QEMU_PUBKEY__
package_update: true
packages:
  - bats
  - jq
  - ca-certificates
  - curl
  - expect
write_files:
  - path: /etc/ssh/sshd_config.d/10-agentlinux-test-acceptenv.conf
    permissions: '0644'
    owner: root:root
    content: |
      # Forwarded by the release-gate harness from the host runner into the
      # in-guest bats process. The host-side `ssh -o SendEnv=ANTHROPIC_API_KEY`
      # in tests/qemu/boot.sh pairs with this AcceptEnv drop-in — sshd silently
      # drops any SendEnv var not listed here, so this file is what lets the
      # sandbox key cross the host-to-guest boundary into bats. Scoped to the
      # single allowlisted var (not `AcceptEnv *`) so a future test cannot
      # accidentally smuggle other host-env vars into the guest.
      AcceptEnv ANTHROPIC_API_KEY
runcmd:
  - systemctl enable --now ssh
  - systemctl reload ssh
