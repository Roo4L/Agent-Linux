#!/usr/bin/env expect
# tests/bats/helpers/expect/claude-login.exp
# AGT-02d behavioral test driver: drive `claude /login` non-interactively
# with the API key from the environment. Owns the pty pair so Bun/Ink
# raw-mode TTY succeeds — `script(1)` and `<<<` cannot satisfy raw-mode
# (see the AGT-03 commentary in tests/bats/50-agents.bats for the pattern
# that motivated this helper).
#
# Invariants:
#   - `log_user 0` MANDATORY: suppresses stdout echo of the spawned process.
#     Without it, the API key the script sends back lands in the bash
#     wrapper's stdout — bats captures that as $output — and into CI logs.
#   - Reads ANTHROPIC_API_KEY from env (NOT argv): keeps the key out of
#     /proc/<pid>/cmdline and `ps` output for the expect invocation.
#   - The key is `string trim`-stripped before sending: a value piped in
#     from `cat sandbox-key.txt` carries a trailing newline which most
#     TUIs interpret as submit, truncating the key by one byte.
#   - Tolerant `-re` prompt match: upstream CLI wording shifts between
#     releases. The 30s per-prompt timeout makes upstream changes fail
#     loudly rather than hanging the bats run. Success markers use
#     multi-character anchors only — bare `>` or `$ ` would false-match
#     against banner box-drawing or tip-of-the-day text.
#   - Exit codes: 0 success, 1 prompt timeout / auth failure.

log_user 0
set timeout 30

if {![info exists env(ANTHROPIC_API_KEY)] || $env(ANTHROPIC_API_KEY) eq ""} {
    puts stderr "claude-login.exp: ANTHROPIC_API_KEY env var unset or empty"
    exit 1
}

set api_key [string trim $env(ANTHROPIC_API_KEY)]

# Spawn the in-tool login flow. The exact subcommand shape (`claude /login`
# vs `claude login` vs an interactive `/login` slash-command at the REPL) is
# upstream-controlled; if the live CLI surface differs, update this spawn
# line AND the debugging checklist in docs/internals/test-interactive.md.
spawn claude /login

expect {
    -re {[Aa]pi[ _-]?[Kk]ey|[Pp]aste.*key} {
        send -- "$api_key\r"
    }
    timeout {
        puts stderr "claude-login.exp: timed out waiting for API-key prompt (30s)"
        exit 1
    }
    eof {
        puts stderr "claude-login.exp: process exited before API-key prompt"
        exit 1
    }
}

# Wait for a success signal — login confirmation. Multi-character anchors
# only; bare `>` and `$ ` are too greedy.
expect {
    -re {[Ll]ogged in|[Ss]uccessfully|[Ww]elcome} {
        send "\004"
        expect eof
        exit 0
    }
    -re {[Ii]nvalid|[Uu]nauthorized|[Ff]ailed} {
        puts stderr "claude-login.exp: login rejected (auth failure)"
        exit 1
    }
    timeout {
        puts stderr "claude-login.exp: timed out waiting for login confirmation (30s)"
        exit 1
    }
}
