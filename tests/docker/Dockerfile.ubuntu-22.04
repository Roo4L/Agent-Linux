# tests/docker/Dockerfile.ubuntu-22.04
# Systemd-capable Ubuntu 22.04 base for running the full BHV matrix in CI.
# Source: docs.docker.com, ADR-007, jrei/systemd-ubuntu, 02-RESEARCH.md §Pitfall 3.
#
# Invariants (identical to the 24.04 variant — only FROM differs):
#   - PID 1 = systemd (CMD ["/sbin/init"]) so BHV-04 (systemd User=agent) is real,
#     not vacuously skipped. Requires `--privileged --cgroupns=host` at runtime.
#   - cron + openssh-server installed so BHV-02/BHV-03 helpers have a daemon to
#     talk to (systemd units start them once PID 1 is up).
#   - bats installed system-wide (22.04 apt ships 1.2.1, which predates the
#     BATS_TEST_TMPDIR export added in bats 1.4.0 — fixtures must not assume that
#     variable is set; see tests/bats/helpers/tmpdir.bash).
#   - locales + C.UTF-8 update-locale seeded so BHV-01 locale checks fire against
#     a real system configuration, not Docker's DEBIAN_FRONTEND env override.
#   - sudo present so run_sudo_u / run_sudo_u_i helpers can exercise BHV-05.
#   - --no-install-recommends keeps the image small (attack surface + pull time).
#
# Phase 4 (Plan 04-06) extension:
#   - Multi-stage builder (node:22-slim) compiles plugin/cli/ via pnpm at image
#     build time. The compiled dist/ is copied into the final image at
#     /opt/cli-prebuilt/dist; tests/docker/run.sh splices it into the staged
#     source tree at /opt/agentlinux-src/plugin/cli/dist/ before invoking
#     agentlinux-install, so the 50-registry-cli.sh provisioner finds the
#     compiled CLI entrypoint. plugin/cli/dist/ is gitignored — this is how
#     the installer's runtime CLI lands in the test image without relying on
#     the host having run `pnpm run build` first.
#   - The final test image remains Ubuntu 22.04 (faithful test substrate); the
#     installer's OWN NodeSource setup runs at runtime during the test — that
#     is part of what is under test, not a build-time dependency.

# ---------------------------------------------------------------
# Stage 1: cli-builder — compile plugin/cli/ via pnpm on node:22-slim.
# node:22-slim ships Node + npm + corepack, so there is no NodeSource apt
# touchpoint at Docker-build time (Docker-build hermeticity). Copies ONLY
# plugin/cli/ into the builder so the build cache keys on CLI sources, not
# the full repo. Build context for this Dockerfile is the repo root (set by
# tests/docker/run.sh).
# ---------------------------------------------------------------
FROM node:22-slim AS cli-builder
WORKDIR /build/cli
# Copy package manifests first for Docker-layer cache hit on source-only edits.
COPY plugin/cli/package.json plugin/cli/pnpm-lock.yaml ./
COPY plugin/cli/tsconfig.json ./
COPY plugin/cli/src ./src
# corepack ships with node 22+; activate pnpm (version pinned by package.json
# engines/packageManager if present, else latest 9.x from the corepack channel).
# --frozen-lockfile = fail if lockfile drift; --prod would skip devDeps but
# tsc is a devDep, so we need the full install here, then prune devDeps after
# build to minimize the node_modules/ we ship into the final image.
RUN corepack enable \
    && corepack prepare pnpm@latest --activate \
    && pnpm install --frozen-lockfile \
    && pnpm run build \
    && pnpm prune --prod

# ---------------------------------------------------------------
# Stage 2: final test image — Ubuntu 22.04 + systemd-in-docker.
# ---------------------------------------------------------------
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# Core: systemd + cron + openssh + bats + sudo + locales + coreutils + shellcheck.
# dbus is REQUIRED for BHV-04: `systemd-run --uid=agent` needs a reachable
# system bus or it errors with "Failed to connect to bus: No such file or
# directory" and the test fails vacuously (02-05 Rule 3 auto-fix: discovered
# on local Docker smoke test before CI ever saw it).
# jq is REQUIRED by Phase 4's tests/bats/40-registry-cli.bats to parse
# `agentlinux list --json` output and inspect sentinel JSON files
# (/opt/agentlinux/state/installed.d/<id>.json). Plan 04-07 Rule 3 auto-fix.
# Phase 12 (Plan 12-03): tests/bats/15-detection.bats's read-only invariant
# @test snapshots /etc /home /usr/local/bin /opt before+after a detection
# pass and asserts byte-equality. jq must be pre-installed here so the
# detection-layer's ensure_jq fallback (apt-get install jq) is a no-op,
# otherwise the snapshot would diff /var/lib/dpkg/* and fail.
# curl is REQUIRED by Phase 5's claude-code install.sh recipe (AGT-02 path):
# `curl -fsSL https://claude.ai/install.sh | bash -s $PINNED` fetches the
# native-installer bootstrap. Ubuntu 22.04 minimal does NOT ship curl by
# default — without this, the release-gate bats file's setup_file fails at
# `agentlinux install --force claude-code`. Plan 05-01 Rule 3 auto-fix.
# python3 is REQUIRED by Phase 6's tests/bats/60-curl-installer.bats: the
# INST-03 fixture runs `python3 -m http.server` in setup_file to serve a
# local fake tarball + .sha256 — no live network in CI. Plan 06-02 addition.
# `file` is REQUIRED by packaging/curl-installer/install.sh Pitfall-2 gzip
# magic sanity check (see install.sh line ~155). Plan 06-02 addition.
# expect is REQUIRED by the interactive bats helpers under
# tests/bats/helpers/expect/. Drives `claude /login` and idle-session paths
# via a real pty pair (Bun/Ink raw-mode TTY requirement). Apt main pocket
# on 22.04 + 24.04 + 26.04.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      systemd systemd-sysv \
      cron openssh-server \
      bats locales sudo \
      dbus \
      expect \
      jq \
      curl \
      python3 \
      file \
      ca-certificates bash coreutils util-linux \
      shellcheck && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Systemd inside Docker: mask units that fight with containerized PID 1.
RUN rm -f /lib/systemd/system/multi-user.target.wants/* && \
    systemctl mask \
      systemd-logind.service \
      systemd-resolved.service \
      systemd-networkd.service \
      systemd-tmpfiles-setup.service \
      systemd-tmpfiles-clean.service \
      systemd-tmpfiles-clean.timer

# SSH: generate host keys at build time (daemon is started later by systemd).
RUN mkdir -p /run/sshd && ssh-keygen -A

# Locale: C.UTF-8 is a glibc built-in on 22.04+; locale-gen is a no-op but the
# update-locale write into /etc/default/locale is the real correctness step.
RUN locale-gen C.UTF-8 || true && update-locale LANG=C.UTF-8 LC_ALL=C.UTF-8

# Phase 4 Plan 04-06: copy the pre-built CLI dist/ + production-pruned
# node_modules/ + package.json from the builder stage. tests/docker/run.sh
# splices the TRIO into /opt/agentlinux-src/plugin/cli/ after staging the
# bind-mounted /workspace copy, so the 50-registry-cli.sh provisioner finds
# a runnable CLI bundle at install time. node_modules/ is required because
# dist/index.js contains ESM `import … from 'commander'` — Node's module
# resolver walks up from dist/ and finds deps in a sibling node_modules/.
COPY --from=cli-builder /build/cli/dist /opt/cli-prebuilt/dist
COPY --from=cli-builder /build/cli/node_modules /opt/cli-prebuilt/node_modules
COPY --from=cli-builder /build/cli/package.json /opt/cli-prebuilt/package.json

# cgroup bind + SIGRTMIN+3 graceful-stop required by systemd-as-PID-1 recipe.
VOLUME /sys/fs/cgroup
STOPSIGNAL SIGRTMIN+3

# /sbin/init is systemd — Pitfall 3 mitigation.
CMD ["/sbin/init"]
