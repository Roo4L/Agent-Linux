#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# plugin/bin/agentlinux-install — AgentLinux installer entrypoint
# Phase 2 (v0.3.0): provisions the agent user + PATH wiring across six
# invocation modes.
#
# Refs: docs/HARNESS.md §1.1; .claude/skills/agentlinux-installer/SKILL.md;
#       .planning/phases/02-installer-foundation-agent-user/02-RESEARCH.md
#       §Pattern 1, §Pitfall 6, §Example 1; 02-CONTEXT.md "Installer UX & Logging".
set -euo pipefail

readonly LOG_FILE="${AGENTLINUX_LOG:-/var/log/agentlinux-install.log}"

# Phase 14 (Plan 14-01 — UX-05): structured exit code constants per CONTEXT.md
# Area 1 Q3. 64=usage (bad CLI flags); 65=data (incompatible host state — bail
# without --yes). Used throughout via `exit "$EX_USAGE"` / `exit "$EX_DATAERR"`
# for grep stability. The bash readonly declaration is intentional — these are
# the canonical values referenced by CI wrappers + the bail message footer.
# EX_DATAERR is referenced from plugin/lib/remediate.sh's flush_bails_or_continue
# (literal `exit 65` per CONTEXT.md Q3 grep-stability requirement) — declared
# here as the source-of-truth so a future refactor that ties the literal back
# to the constant has a single readonly to consult. shellcheck cannot follow
# cross-file references through `. "$LIB_DIR/remediate.sh"`, hence SC2034.
# shellcheck disable=SC2034
readonly EX_USAGE=64
# shellcheck disable=SC2034
readonly EX_DATAERR=65
# Resolve script-relative directories. Split `declare`/`assign` per SC2155 so
# a cmdsub failure surfaces as a non-zero return instead of being masked by
# the `readonly` wrapper.
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly BIN_DIR
LIB_DIR="$(cd "$BIN_DIR/../lib" && pwd)"
readonly LIB_DIR
PROV_DIR="$(cd "$BIN_DIR/../provisioner" && pwd)"
readonly PROV_DIR

# AL-29: derive AGENTLINUX_VERSION from the co-shipped plugin/cli/package.json
# rather than a hardcoded constant. Single source-of-truth: bumping
# package.json now propagates to the bash installer, the registry CLI, the
# bats test suite, and the release pipeline's three-way version lock. The
# previous hardcoded constant drifted in v0.3.2-rc1 (silently broke CAT-05
# because the staged catalog landed at /opt/agentlinux/catalog/0.3.0/ while
# package.json said 0.3.2).
#
# Why sed-not-jq: the entrypoint runs BEFORE 30-nodejs.sh which (transitively
# via apt-get) brings jq onto bare Ubuntu. Coreutils-only extraction is
# sufficient because we control the package.json shape — it is checked into
# this repo with a fixed format. The version-regex check below catches any
# format drift loudly.
PKG_JSON="$BIN_DIR/../cli/package.json"
readonly PKG_JSON
[[ -r "$PKG_JSON" ]] \
  || {
    printf 'agentlinux-install: package.json not readable at %s\n' "$PKG_JSON" >&2
    exit 1
  }
AGENTLINUX_VERSION=$(sed -nE 's/^[[:space:]]*"version":[[:space:]]*"([^"]+)".*/\1/p' \
  "$PKG_JSON" | head -n 1)
[[ "$AGENTLINUX_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+([-.][A-Za-z0-9.-]+)?$ ]] \
  || {
    printf 'agentlinux-install: bad or missing version in %s: %q\n' \
      "$PKG_JSON" "$AGENTLINUX_VERSION" >&2
    exit 1
  }
readonly AGENTLINUX_VERSION

usage() {
  cat <<EOF
agentlinux-install v${AGENTLINUX_VERSION} — provision an agent user and environment

Usage: agentlinux-install [OPTIONS]

Options:
  -h, --help            Show this help and exit
  -V, --version         Print version and exit
      --verbose         Enable DEBUG-level logging
      --purge           Remove the agent user, /opt/agentlinux/, and all
                        installer-placed files (requires root; destructive)
      --remove-nodejs   Used WITH --purge: also apt-get purge nodejs. Other
                        users may depend on Node.js, so this is NOT the
                        default purge behavior.
      --report-only     Run detection pass + emit report; exit 0 without
                        running provisioners. Read-only.
      --report-format=FMT  text (default) or json. Honored with --report-only.
      --user=NAME       Install-user name to probe (default: agent).
      --yes             Non-TTY consent for state-overwriting Remediate
                        actions (REMEDIATE-01 chown/rebase, REMEDIATE-03
                        sudoers drift overwrite, REMEDIATE-04 broken-agent
                        reinstall). Additive Remediates run unconditionally.
                        Consent is via --yes ONLY — no environment-variable
                        equivalent is recognized (T-14-01: avoid spoofable
                        consent surfaces).
      --no-yes          Explicit opposite of --yes (default). Provided so
                        CI wrappers can toggle consent from a variable
                        without rebuilding argv. Contradicts --yes (the
                        installer exits with usage error in that case).
      --dry-run         Run detection + decisions, print the pre-flight
                        report, exit 0 WITHOUT mutating host state. Covers
                        the full Phase 12-14 decision pipeline (bails
                        surface IN the report, NOT as exit code). Useful
                        before a real install to preview what will happen.
                        Contradicts --yes (exit 64) — dry-run never mutates,
                        --yes is a mutation gate.

The installer must run as root. Supported hosts: Ubuntu 22.04, 24.04 and 26.04.
Transcript: ${LOG_FILE}

Exit codes:
  0   success — install completed, report printed, or dry-run finished
  1   runtime — execution failure during Create or Remediate (apt, chown, useradd, install.sh)
  64  usage   — bad command-line flags or contradictory options
  65  data    — incompatible host state surfaced by detection (run --dry-run to preview)

  Most actionable in non-TTY contexts (cron, CI, curl|bash): exit 65 means
  state-overwriting Remediate would be required — re-run with --yes to apply.
EOF
}

# pre_parse_args — handle the two print-and-exit flags (--help, --version)
# BEFORE the log-file / tee / require_root machinery kicks in. These flags
# mutate no state, so running them without root is part of the UX contract
# (CONTEXT.md "Installer UX & Logging", PLAN acceptance criterion "parse_args
# runs BEFORE require_root so --help / --version work without sudo").
#
# --purge was handled here in Phase 2 as a print-and-exit stub. Phase 4 Plan
# 04-06 moves --purge to parse_args + main() so it runs AFTER require_root
# (--purge is destructive and requires EUID=0). --verbose and unknown flags
# fall through to parse_args (run after log-init) so their diagnostics are
# captured by the tee transcript.
pre_parse_args() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s\n' "$AGENTLINUX_VERSION"
        exit 0
        ;;
    esac
  done
}

pre_parse_args "$@"

# Initialize the log file BEFORE redirecting stdio into it so tee does not
# race on a missing target and a root-owned 0644 file is created atomically.
# Note (A7 in 02-RESEARCH.md): `install -m 0644` follows symlinks. Acceptable
# for a root installer on a clean Ubuntu host; paranoid multi-tenant hosts
# revisit in v0.4+.
# Fallback to stderr (not the log!) on failure so the operator sees why
# bootstrap aborted even before tee is active.
if ! install -m 0644 /dev/null "$LOG_FILE" 2>/dev/null; then
  printf 'agentlinux-install: cannot create %s (are you root?)\n' "$LOG_FILE" >&2
  exit "$EX_USAGE"
fi

# Tee everything to the log. Merge stderr into stdout AFTER the tee redirect
# so both streams land in the single greppable transcript that INST-05 scans.
# Pitfall 6 mitigation: the async `tee` child needs EOF on its stdin before it
# will flush and exit. Closing FD 1 (+ FD 2, which was dup'd from FD 1) before
# `wait` is what delivers EOF; a bare `trap wait EXIT` deadlocks because the
# EXIT trap runs *before* bash drops the caller's FDs, so tee never sees the
# pipe close. We also save the tee PID via `$!` so `wait` targets just tee
# rather than any unrelated backgrounded children.
exec > >(tee -a "$LOG_FILE") 2>&1
TEE_PID=$!
readonly TEE_PID
trap 'exec >&- 2>&-; wait "$TEE_PID" 2>/dev/null || true' EXIT

# log.sh FIRST — every downstream lib (distro_detect, idempotency, as_user)
# checks `command -v log_error` at top and hard-fails if log.sh is missing.
# shellcheck source=../lib/log.sh
. "$LIB_DIR/log.sh"

on_error() {
  local exit_code=$?
  local line_no=${BASH_LINENO[0]:-unknown}
  local src=${BASH_SOURCE[1]:-unknown}
  log_error "installer failed at $(basename "${src}"):${line_no} (exit ${exit_code})"
  log_error "full transcript: ${LOG_FILE}"
  # Flush the tee child before exit; ignore failure on read-only /proc etc.
  sync 2>/dev/null || true
  exit "$exit_code"
}
trap on_error ERR

# shellcheck source=../lib/distro_detect.sh
. "$LIB_DIR/distro_detect.sh"
# shellcheck source=../lib/idempotency.sh
. "$LIB_DIR/idempotency.sh"
# shellcheck source=../lib/as_user.sh
. "$LIB_DIR/as_user.sh"

# Global flag state set by parse_args; main() consults these AFTER require_root
# to branch into run_purge vs the normal provisioner flow.
PURGE_REQUESTED=false
REMOVE_NODEJS_REQUESTED=false
# Phase 12 (Plan 12-01): detection-layer flag state. REPORT_ONLY gates
# run_provisioners; REPORT_FORMAT chooses the renderer (text/json); INSTALL_USER
# is the install-user name passed to detect::run_once. Defaults preserve the
# v0.3.0 greenfield behavior — without --report-only, main() falls through to
# run_provisioners exactly as before.
REPORT_ONLY=false
REPORT_FORMAT=text
INSTALL_USER=agent
# Phase 14 (Plan 14-01 — UX-03): --yes / --no-yes consent flag state.
# YES_FLAG=true authorizes state-overwriting Remediate actions in non-TTY mode
# (REMEDIATE-01 chown/rebase, REMEDIATE-03 sudoers drift, REMEDIATE-04 reinstall).
# YES_FLAG_EXPLICIT_NO=true records that --no-yes was passed so a subsequent
# --yes can be rejected as contradictory (T-14-02 mitigation — argv must be
# unambiguous; no "last flag wins" fallback).
YES_FLAG=false
YES_FLAG_EXPLICIT_NO=false
# Phase 15 (Plan 15-01 — UX-01 / D-15-01): --dry-run flag state. When true,
# main() runs detect::run_once + remediate::collect_all_decisions +
# detect::emit_report and exits 0 BEFORE flush_bails_or_continue and
# run_provisioners — observably non-mutating. T-15-01-02 mitigation is the
# byte-identical snapshot @test that proves this branch performs zero host
# mutation. D-15-04: --dry-run + --yes is contradictory (exit 64) in both
# orders — see the symmetric guards in parse_args below.
DRY_RUN_REQUESTED=false

# parse_args — handle flags that either mutate installer state (--verbose,
# --purge, --remove-nodejs) or need the log transcript for diagnostics
# (unknown-flag rejection). Runs after log-init so every message routes
# through the tee.
#
# --help / --version are handled by pre_parse_args above and never reach
# this function; they are kept in this case-match only as a defensive
# fallthrough (should pre_parse_args be refactored).
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s\n' "$AGENTLINUX_VERSION"
        exit 0
        ;;
      --verbose)
        export AGENTLINUX_LOG_LEVEL=DEBUG
        log_debug "verbose logging enabled"
        ;;
      --purge)
        PURGE_REQUESTED=true
        ;;
      --remove-nodejs)
        REMOVE_NODEJS_REQUESTED=true
        ;;
      --report-only)
        REPORT_ONLY=true
        ;;
      --report-format=*)
        REPORT_FORMAT="${1#*=}"
        ;;
      --report-format)
        shift
        [[ $# -gt 0 ]] || {
          log_error "--report-format requires a value (text|json)"
          exit "$EX_USAGE"
        }
        REPORT_FORMAT="$1"
        ;;
      --user=*)
        INSTALL_USER="${1#*=}"
        ;;
      --user)
        shift
        [[ $# -gt 0 ]] || {
          log_error "--user requires a value"
          exit "$EX_USAGE"
        }
        INSTALL_USER="$1"
        ;;
      --yes)
        # T-14-02 mitigation: contradictory --no-yes-then-yes exits 64
        # rather than silently picking last-flag-wins. argv must be
        # unambiguous.
        if [[ "$YES_FLAG_EXPLICIT_NO" == true ]]; then
          log_error "agentlinux-install: contradictory flags — --no-yes preceded --yes"
          exit "$EX_USAGE"
        fi
        # Phase 15 Plan 15-01 (D-15-04 symmetric / T-15-01-06): --yes after
        # --dry-run is also contradictory — --dry-run never mutates, --yes is
        # a mutation gate. Symmetric to the --dry-run case-arm below.
        if [[ "$DRY_RUN_REQUESTED" == true ]]; then
          log_error "agentlinux-install: contradictory flags — --dry-run forbids --yes (dry-run never mutates; --yes is a mutation gate)"
          exit "$EX_USAGE"
        fi
        YES_FLAG=true
        ;;
      --dry-run)
        # Phase 15 Plan 15-01 (D-15-04 / T-15-01-06): --dry-run forbids --yes.
        # If --yes was already passed, reject before flipping the flag — argv
        # must be unambiguous about whether mutation is allowed.
        if [[ "$YES_FLAG" == true ]]; then
          log_error "agentlinux-install: contradictory flags — --dry-run forbids --yes (dry-run never mutates; --yes is a mutation gate)"
          exit "$EX_USAGE"
        fi
        DRY_RUN_REQUESTED=true
        ;;
      --no-yes)
        # Symmetric T-14-02: --yes-then-no-yes also rejected.
        if [[ "$YES_FLAG" == true ]]; then
          log_error "agentlinux-install: contradictory flags — --yes preceded --no-yes"
          exit "$EX_USAGE"
        fi
        YES_FLAG_EXPLICIT_NO=true
        ;;
      *)
        log_error "unknown argument: $1"
        usage >&2
        exit "$EX_USAGE"
        ;;
    esac
    shift
  done

  # Validate REPORT_FORMAT after the loop. Only `text` or `json` allowed;
  # anything else is a usage error (exit 64 / EX_USAGE per the v0.3.0
  # convention used by --help / --version's pre_parse_args fallthrough).
  case "$REPORT_FORMAT" in
    text | json) ;;
    *)
      log_error "--report-format must be 'text' or 'json' (got: ${REPORT_FORMAT})"
      exit "$EX_USAGE"
      ;;
  esac
}

# ensure_jq — install jq if absent. Required by detection-layer's jq -n /
# jq -s 'add' / jq '.' calls (DET-01..06 + orchestrator). Mirrors the visudo
# install fallback in plugin/provisioner/20-sudoers.sh:45-48: jq is pre-installed
# on the test Docker images (tests/docker/Dockerfile.ubuntu-{22,24,26}.04 line
# ~92), but minimal Ubuntu cloud images and bare base containers can ship
# without it. apt-get install is idempotent — a no-op when present. The bats
# no-op @test in Plan 12-03 runs against the Docker fixture where jq is already
# installed, so this fallback never mutates host state during the @test.
ensure_jq() {
  if ! command -v jq >/dev/null 2>&1; then
    log_warn "jq not found; installing 'jq' package (required by detection layer)"
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends jq
  fi
}

require_root() {
  if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
    log_error "agentlinux-install must run as root (EUID != 0). Re-run under sudo."
    exit "$EX_USAGE"
  fi
}

run_provisioners() {
  local step
  local -a steps
  # `compgen -G` expands the glob via bash's builtin and returns matches on
  # stdout in directory-entry order (NOT guaranteed lexical — on ext4/overlayfs
  # the order depends on inode allocation, so a later-created `30-nodejs.sh`
  # can precede `10-agent-user.sh`). Pipe through `sort` to enforce the
  # numeric-dispatch contract (10 → 30 → 40 → ...). The compgen trailing
  # `|| true` keeps the empty-match case (no provisioner files yet) from
  # tripping `set -e` — caller's length-check below then short-circuits with
  # a warn. Using compgen sidesteps shfmt 3.8.0's lexer misreading
  # `[0-9][0-9]` in an array assignment as an array subscript.
  mapfile -t steps < <(compgen -G "$PROV_DIR/[0-9][0-9]-*.sh" | sort || true)
  if [[ ${#steps[@]} -eq 0 ]]; then
    log_warn "no provisioner scripts found under ${PROV_DIR} (Phase 2 provisioners land in sibling plans)"
    return 0
  fi
  for step in "${steps[@]}"; do
    log_info "running $(basename "$step")"
    # shellcheck disable=SC1090
    . "$step"
  done
}

# run_purge [remove_nodejs_flag]
#
# INST-04 wire-up — replaces the Phase 2 stub. Ordered 7-step teardown; every
# step is idempotent (rm -f no-op on missing, userdel guarded by id check,
# pkill -u guarded by true).
#
# Ordering contract (Pitfall 7 + security-engineer rubric):
#   1. per-agent uninstall.sh (REQUIRES /opt/agentlinux/catalog/ still present)
#   2. rm /opt/agentlinux                          (literal absolute path)
#   3. PATH artefacts (profile.d, agentlinux.env, cron.d)
#   4. NodeSource apt repo files
#   5. (optional) apt-get purge nodejs when $1 == true
#   6. userdel -r agent (pkill first to avoid "user is logged in" refusal)
#   7. LAST — rm /var/log/agentlinux-install.log (the tee is still writing
#      to this file during our run; the EXIT trap at the top of this script
#      closes FD 1+2, delivering EOF to tee. We do the rm LAST so any
#      post-unlink writes land in the unlinked inode that is GC'd after exit.
#      Per Pitfall 7, sequencing log removal LAST avoids mid-invocation FD
#      write-into-/dev/null footguns.)
#
# Security invariants (T-04-16):
#   - Every rm target is a LITERAL absolute path (no $VAR in rm -rf).
#   - Recipe paths derive from $AGENTLINUX_VERSION (controlled by entrypoint,
#     not user input) and the sentinel filename (basename -- NO file-contents
#     grep/eval on agent-writable sentinel JSON).
#   - --remove-nodejs is opt-in (T-04-17); default leaves Node installed.
run_purge() {
  local remove_nodejs=${1:-false}

  log_info "running --purge (destructive)"

  # Step 1: per-agent uninstall.sh for every sentinel.
  # Look up recipe paths from the catalog snapshot keyed by sentinel id —
  # DO NOT trust paths from sentinel JSON contents (a tampered sentinel
  # shouldn't pick arbitrary scripts to execute as agent).
  local state_dir=/opt/agentlinux/state/installed.d
  if [[ -d $state_dir ]]; then
    local f
    for f in "$state_dir"/*.json; do
      [[ -f $f ]] || continue
      local id
      id=$(basename "$f" .json)
      local recipe=/opt/agentlinux/catalog/${AGENTLINUX_VERSION}/agents/${id}/uninstall.sh
      if [[ -x $recipe ]]; then
        log_info "running uninstall.sh for ${id}"
        # as_user's sudo line already appends `--`; passing a second `--`
        # would resolve to `sudo -u agent -H -E -- -- bash <recipe>` and sudo
        # would try to exec `--` ("command not found"). Pass the command
        # verbatim without our own terminator.
        # Recipes guard on `${AGENTLINUX_AGENT_HOME:?}` (set by runner.ts on
        # normal install/remove). On --purge runner.ts is gone; provide it
        # explicitly so the guard does not trip.
        AGENTLINUX_AGENT_HOME=/home/agent \
          as_user agent bash "$recipe" || log_warn "uninstall.sh for ${id} failed (continuing)"
      else
        log_warn "no uninstall.sh for ${id} at ${recipe}; skipping"
      fi
      rm -f -- "$f"
    done
  fi

  # Step 2: remove /opt/agentlinux (CLI dist, catalog snapshot, state).
  # Literal absolute path — security-engineer rubric flags any $VAR in rm -rf.
  rm -rf /opt/agentlinux/

  # Step 3: PATH artefacts placed by 40-path-wiring.sh.
  rm -f /etc/profile.d/agentlinux.sh
  rm -f /etc/agentlinux.env
  rm -f /etc/cron.d/agentlinux

  # Step 3.5: sudoers drop-in placed by 20-sudoers.sh (Phase 5.1 / ADR-012).
  # Symmetric uninstall must remove the NOPASSWD grant — leaving it behind
  # orphans the privilege after the agent user is gone.
  rm -f /etc/sudoers.d/agentlinux

  # Step 4: NodeSource apt repo files placed by 30-nodejs.sh.
  # Both filenames (deb822 + legacy) handled — setup_22.x may have created
  # either depending on Ubuntu version / prior partial migrations.
  rm -f /etc/apt/sources.list.d/nodesource.sources
  rm -f /etc/apt/sources.list.d/nodesource.list
  rm -f /etc/apt/preferences.d/nodejs

  # Step 5: optionally apt-remove nodejs. Explicit opt-in (T-04-17) — other
  # users on this host may depend on Node installed by this installer.
  if [[ $remove_nodejs == true ]]; then
    log_info "removing nodejs (apt-get purge -y nodejs)"
    DEBIAN_FRONTEND=noninteractive apt-get purge -y nodejs || log_warn "apt purge nodejs failed"
    DEBIAN_FRONTEND=noninteractive apt-get autoremove -y || true
  fi

  # Step 6: remove agent user + /home/agent.
  # pkill -u agent first to avoid "user is logged in" from userdel when an
  # SSH session or systemd-run scope is live. pkill returns non-zero if no
  # matches; that is fine — ignore.
  if id agent >/dev/null 2>&1; then
    pkill -u agent 2>/dev/null || true
    sleep 1
    if ! userdel -r agent 2>/dev/null; then
      log_warn "userdel -r agent failed; trying userdel -rf"
      userdel -rf agent 2>/dev/null || log_error "could not remove agent user"
    fi
  fi

  # Step 7: LAST — remove the install log. See ordering contract above.
  # Pitfall 7 mitigation: sequence LAST so the tee child sees EOF naturally
  # on script exit (EXIT trap closes FDs; unlinked inode is GC'd).
  log_info "--purge complete"
  rm -f /var/log/agentlinux-install.log
}

main() {
  parse_args "$@"
  require_root
  if [[ $PURGE_REQUESTED == true ]]; then
    run_purge "$REMOVE_NODEJS_REQUESTED"
    exit 0
  fi
  # Phase 12 (Plan 12-01): in --report-format=json mode, the JSON object on
  # stdout MUST be the only thing downstream consumers see — `agentlinux-install
  # --report-only --report-format=json | jq` is the canonical use. Suppressing
  # the banner log_info calls in this single mode keeps the JSON unpolluted
  # without changing the transcript invariant for the greenfield path (which
  # still emits both banners exactly as v0.3.0 did). The text-format report and
  # all other paths are unchanged.
  local json_quiet=false
  if [[ $REPORT_ONLY == true && $REPORT_FORMAT == json ]]; then
    json_quiet=true
  fi
  [[ $json_quiet == true ]] || log_info "agentlinux-install v${AGENTLINUX_VERSION} starting"
  if [[ $json_quiet == true ]]; then
    # Route detect_distro's log_info "detected ubuntu X.YZ" to /dev/null in
    # JSON mode (still tee'd to /var/log via the parent redirect). detect_distro
    # itself returns non-zero on unsupported distros, which still trips the ERR
    # trap and aborts before any JSON emit.
    detect_distro >/dev/null 2>&1
  else
    detect_distro
  fi
  # Phase 12: ensure jq is present, source detect.sh, and run the read-only
  # detection pass. Both --report-only and the greenfield path call
  # detect::run_once so /run/agentlinux-detect.json is populated for Phase 13's
  # REUSE provisioners (which source detect.sh and consult the cached readers).
  # --report-only short-circuits BEFORE run_provisioners — exit 0 after the
  # report is emitted. The no-flag path proceeds to run_provisioners exactly as
  # in v0.3.0 (greenfield baseline 66/66 untouched).
  if [[ $json_quiet == true ]]; then
    ensure_jq >/dev/null 2>&1
  else
    ensure_jq
  fi
  # shellcheck source=../lib/detect.sh
  . "$LIB_DIR/detect.sh"
  if [[ $json_quiet == true ]]; then
    detect::run_once "$INSTALL_USER" >/dev/null 2>&1
  else
    detect::run_once "$INSTALL_USER"
  fi
  # Phase 13 (Plan 13-01): source the reuse-decision orchestrator AFTER
  # detect::run_once has populated DETECT_* exports, BEFORE run_provisioners.
  # Sourcing is unconditional (independent of --report-only) so the dispatch
  # surface is available to any future Phase 15 dry-run that wants to surface
  # reuse decisions; reuse.sh emits no output by itself so the JSON-quiet
  # branch above is unaffected. The provisioners (10-agent-user.sh,
  # 30-nodejs.sh) consult reuse::user_decision + reuse::nodejs_decision via
  # case-branch dispatchers near their top — Phase 14 extends the remediate /
  # bail branches without changing the dispatch shape (CONTEXT.md "Phase 13 →
  # Phase 14 contract").
  # shellcheck source=../lib/reuse.sh
  . "$LIB_DIR/reuse.sh"
  if [[ $REPORT_ONLY == true ]]; then
    detect::emit_report "$REPORT_FORMAT"
    exit 0
  fi
  # Phase 14 (Plan 14-01): DECIDE-THEN-ACT main() flow.
  #
  # remediate.sh provides collect_all_decisions (calls every reuse::*_decision,
  # populates RESOLUTIONS map + BAILED_COMPONENTS array — NO MUTATION) and
  # flush_bails_or_continue (exits 65 here if any bail accumulated, returns 0
  # otherwise — STILL NO MUTATION). Both run BEFORE run_provisioners so a host
  # that bails NEVER sees a partially-mutated state. The no-mutation snapshot
  # @tests in tests/bats/14-remediate.bats (Tests 19-22) prove the atomicity
  # invariant byte-for-byte against /etc/sudoers.d/, /home/, /etc/passwd.
  # shellcheck source=../lib/remediate.sh
  . "$LIB_DIR/remediate.sh"
  remediate::collect_all_decisions
  # Phase 15 (Plan 15-01 — UX-01 / D-15-01): --dry-run early-return. Runs AFTER
  # collect_all_decisions (so the report reflects every decision the real
  # install would have made — including state-overwriting Remediates that
  # would otherwise have been gated by --yes) and BEFORE
  # flush_bails_or_continue (D-15-01: bails surface IN the report, NOT via
  # exit code 65). Always exits 0 — preview semantic, mirrors `terraform plan`
  # / `apt --simulate` Unix conventions. T-15-01-02 mitigation: by exiting
  # before flush_bails_or_continue + run_provisioners, this branch performs
  # ZERO host mutation; the no-mutation snapshot @test in
  # tests/bats/15-preflight-ux.bats Test 3 proves the invariant byte-for-byte
  # against /etc/sudoers.d, /home, /etc/passwd.
  if [[ "$DRY_RUN_REQUESTED" == true ]]; then
    log_info "[DRY-RUN] pre-flight report (no host mutation):"
    detect::emit_report "$REPORT_FORMAT"
    log_info "[DRY-RUN] exit 0 (no mutation; re-run without --dry-run to apply)"
    exit 0
  fi
  remediate::flush_bails_or_continue
  run_provisioners
  log_info "agentlinux-install complete (transcript: ${LOG_FILE})"
}

main "$@"
