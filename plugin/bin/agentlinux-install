#!/usr/bin/env bash
# plugin/bin/agentlinux-install — AgentLinux installer entrypoint
# Phase 2 (v0.3.0): provisions the agent user + PATH wiring across six
# invocation modes.
#
# Refs: docs/HARNESS.md §1.1; .claude/skills/agentlinux-installer/SKILL.md;
#       .planning/phases/02-installer-foundation-agent-user/02-RESEARCH.md
#       §Pattern 1, §Pitfall 6, §Example 1; 02-CONTEXT.md "Installer UX & Logging".
set -euo pipefail

readonly AGENTLINUX_VERSION="0.3.0"
readonly LOG_FILE="${AGENTLINUX_LOG:-/var/log/agentlinux-install.log}"
# Resolve script-relative directories. Split `declare`/`assign` per SC2155 so
# a cmdsub failure surfaces as a non-zero return instead of being masked by
# the `readonly` wrapper.
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly BIN_DIR
LIB_DIR="$(cd "$BIN_DIR/../lib" && pwd)"
readonly LIB_DIR
PROV_DIR="$(cd "$BIN_DIR/../provisioner" && pwd)"
readonly PROV_DIR

usage() {
  cat <<EOF
agentlinux-install v${AGENTLINUX_VERSION} — provision an agent user and environment

Usage: agentlinux-install [OPTIONS]

Options:
  -h, --help       Show this help and exit
  -V, --version    Print version and exit
      --verbose    Enable DEBUG-level logging
      --purge      (Phase 4 stub) remove the agent user and installer state

The installer must run as root. Supported hosts: Ubuntu 22.04 and 24.04.
Transcript: ${LOG_FILE}
EOF
}

# pre_parse_args — handle the three print-and-exit flags (--help, --version,
# --purge) BEFORE the log-file / tee / require_root machinery kicks in. These
# flags mutate no state, so running them without root is part of the UX
# contract (CONTEXT.md "Installer UX & Logging", PLAN acceptance criterion
# "parse_args runs BEFORE require_root so --help / --version work without
# sudo"). --purge likewise must be usable without root for the deliberate
# no-op warning path in Phase 2 (real wire-up lands in Phase 4).
#
# --verbose and unknown flags fall through to parse_args (run after log-init)
# so their diagnostics are captured by the tee transcript.
pre_parse_args() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s\n' "$AGENTLINUX_VERSION"
        exit 0
        ;;
      --purge)
        printf 'agentlinux-install: --purge is a Phase 4 stub; no action taken in v0.3.0 Phase 2\n' >&2
        exit 0
        ;;
    esac
  done
}

pre_parse_args "$@"

# Initialize the log file BEFORE redirecting stdio into it so tee does not
# race on a missing target and a root-owned 0644 file is created atomically.
# Note (A7 in 02-RESEARCH.md): `install -m 0644` follows symlinks. Acceptable
# for a root installer on a clean Ubuntu host; paranoid multi-tenant hosts
# revisit in v0.4+.
# Fallback to stderr (not the log!) on failure so the operator sees why
# bootstrap aborted even before tee is active.
if ! install -m 0644 /dev/null "$LOG_FILE" 2>/dev/null; then
  printf 'agentlinux-install: cannot create %s (are you root?)\n' "$LOG_FILE" >&2
  exit 64
fi

# Tee everything to the log. Merge stderr into stdout AFTER the tee redirect
# so both streams land in the single greppable transcript that INST-05 scans.
# Pitfall 6 mitigation: the async `tee` child needs EOF on its stdin before it
# will flush and exit. Closing FD 1 (+ FD 2, which was dup'd from FD 1) before
# `wait` is what delivers EOF; a bare `trap wait EXIT` deadlocks because the
# EXIT trap runs *before* bash drops the caller's FDs, so tee never sees the
# pipe close. We also save the tee PID via `$!` so `wait` targets just tee
# rather than any unrelated backgrounded children.
exec > >(tee -a "$LOG_FILE") 2>&1
TEE_PID=$!
readonly TEE_PID
trap 'exec >&- 2>&-; wait "$TEE_PID" 2>/dev/null || true' EXIT

# log.sh FIRST — every downstream lib (distro_detect, idempotency, as_user)
# checks `command -v log_error` at top and hard-fails if log.sh is missing.
# shellcheck source=../lib/log.sh
. "$LIB_DIR/log.sh"

on_error() {
  local exit_code=$?
  local line_no=${BASH_LINENO[0]:-unknown}
  local src=${BASH_SOURCE[1]:-unknown}
  log_error "installer failed at $(basename "${src}"):${line_no} (exit ${exit_code})"
  log_error "full transcript: ${LOG_FILE}"
  # Flush the tee child before exit; ignore failure on read-only /proc etc.
  sync 2>/dev/null || true
  exit "$exit_code"
}
trap on_error ERR

# shellcheck source=../lib/distro_detect.sh
. "$LIB_DIR/distro_detect.sh"
# shellcheck source=../lib/idempotency.sh
. "$LIB_DIR/idempotency.sh"
# shellcheck source=../lib/as_user.sh
. "$LIB_DIR/as_user.sh"

# parse_args — handle flags that either mutate installer state (--verbose) or
# need the log transcript for diagnostics (unknown-flag rejection). Runs after
# log-init so every message routes through the tee.
#
# --help / --version / --purge are handled by pre_parse_args above and never
# reach this function; they are kept in this case-match only as a defensive
# fallthrough (should pre_parse_args be refactored).
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s\n' "$AGENTLINUX_VERSION"
        exit 0
        ;;
      --verbose)
        export AGENTLINUX_LOG_LEVEL=DEBUG
        log_debug "verbose logging enabled"
        ;;
      --purge)
        log_warn "--purge is a Phase 4 stub; no action taken in v0.3.0 Phase 2"
        exit 0
        ;;
      *)
        log_error "unknown argument: $1"
        usage >&2
        exit 64
        ;;
    esac
    shift
  done
}

require_root() {
  if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
    log_error "agentlinux-install must run as root (EUID != 0). Re-run under sudo."
    exit 64
  fi
}

run_provisioners() {
  local step
  local -a steps
  # `compgen -G` expands the glob via bash's builtin, returning matches on
  # stdout in lexical order, or exit 1 with no output when there is no match.
  # This sidesteps shfmt 3.8.0's lexer misreading `[0-9][0-9]` in an array
  # assignment as an array subscript ("[x]" must be followed by =). The
  # trailing `|| true` lets the empty-match case fall through to the array
  # length check below instead of tripping `set -e`.
  mapfile -t steps < <(compgen -G "$PROV_DIR/[0-9][0-9]-*.sh" || true)
  if [[ ${#steps[@]} -eq 0 ]]; then
    log_warn "no provisioner scripts found under ${PROV_DIR} (Phase 2 provisioners land in sibling plans)"
    return 0
  fi
  for step in "${steps[@]}"; do
    log_info "running $(basename "$step")"
    # shellcheck disable=SC1090
    . "$step"
  done
}

main() {
  parse_args "$@"
  require_root
  log_info "agentlinux-install v${AGENTLINUX_VERSION} starting"
  detect_distro
  run_provisioners
  log_info "agentlinux-install complete (transcript: ${LOG_FILE})"
}

main "$@"
