#!/usr/bin/env bash
# plugin/bin/agentlinux-install — AgentLinux installer entrypoint
# Phase 2 (v0.3.0): provisions the agent user + PATH wiring across six
# invocation modes.
#
# Refs: docs/HARNESS.md §1.1; .claude/skills/agentlinux-installer/SKILL.md;
#       .planning/phases/02-installer-foundation-agent-user/02-RESEARCH.md
#       §Pattern 1, §Pitfall 6, §Example 1; 02-CONTEXT.md "Installer UX & Logging".
set -euo pipefail

readonly AGENTLINUX_VERSION="0.3.0"
readonly LOG_FILE="${AGENTLINUX_LOG:-/var/log/agentlinux-install.log}"
# Resolve script-relative directories. Split `declare`/`assign` per SC2155 so
# a cmdsub failure surfaces as a non-zero return instead of being masked by
# the `readonly` wrapper.
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly BIN_DIR
LIB_DIR="$(cd "$BIN_DIR/../lib" && pwd)"
readonly LIB_DIR
PROV_DIR="$(cd "$BIN_DIR/../provisioner" && pwd)"
readonly PROV_DIR

usage() {
  cat <<EOF
agentlinux-install v${AGENTLINUX_VERSION} — provision an agent user and environment

Usage: agentlinux-install [OPTIONS]

Options:
  -h, --help            Show this help and exit
  -V, --version         Print version and exit
      --verbose         Enable DEBUG-level logging
      --purge           Remove the agent user, /opt/agentlinux/, and all
                        installer-placed files (requires root; destructive)
      --remove-nodejs   Used WITH --purge: also apt-get purge nodejs. Other
                        users may depend on Node.js, so this is NOT the
                        default purge behavior.

The installer must run as root. Supported hosts: Ubuntu 22.04 and 24.04.
Transcript: ${LOG_FILE}
EOF
}

# pre_parse_args — handle the two print-and-exit flags (--help, --version)
# BEFORE the log-file / tee / require_root machinery kicks in. These flags
# mutate no state, so running them without root is part of the UX contract
# (CONTEXT.md "Installer UX & Logging", PLAN acceptance criterion "parse_args
# runs BEFORE require_root so --help / --version work without sudo").
#
# --purge was handled here in Phase 2 as a print-and-exit stub. Phase 4 Plan
# 04-06 moves --purge to parse_args + main() so it runs AFTER require_root
# (--purge is destructive and requires EUID=0). --verbose and unknown flags
# fall through to parse_args (run after log-init) so their diagnostics are
# captured by the tee transcript.
pre_parse_args() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s\n' "$AGENTLINUX_VERSION"
        exit 0
        ;;
    esac
  done
}

pre_parse_args "$@"

# Initialize the log file BEFORE redirecting stdio into it so tee does not
# race on a missing target and a root-owned 0644 file is created atomically.
# Note (A7 in 02-RESEARCH.md): `install -m 0644` follows symlinks. Acceptable
# for a root installer on a clean Ubuntu host; paranoid multi-tenant hosts
# revisit in v0.4+.
# Fallback to stderr (not the log!) on failure so the operator sees why
# bootstrap aborted even before tee is active.
if ! install -m 0644 /dev/null "$LOG_FILE" 2>/dev/null; then
  printf 'agentlinux-install: cannot create %s (are you root?)\n' "$LOG_FILE" >&2
  exit 64
fi

# Tee everything to the log. Merge stderr into stdout AFTER the tee redirect
# so both streams land in the single greppable transcript that INST-05 scans.
# Pitfall 6 mitigation: the async `tee` child needs EOF on its stdin before it
# will flush and exit. Closing FD 1 (+ FD 2, which was dup'd from FD 1) before
# `wait` is what delivers EOF; a bare `trap wait EXIT` deadlocks because the
# EXIT trap runs *before* bash drops the caller's FDs, so tee never sees the
# pipe close. We also save the tee PID via `$!` so `wait` targets just tee
# rather than any unrelated backgrounded children.
exec > >(tee -a "$LOG_FILE") 2>&1
TEE_PID=$!
readonly TEE_PID
trap 'exec >&- 2>&-; wait "$TEE_PID" 2>/dev/null || true' EXIT

# log.sh FIRST — every downstream lib (distro_detect, idempotency, as_user)
# checks `command -v log_error` at top and hard-fails if log.sh is missing.
# shellcheck source=../lib/log.sh
. "$LIB_DIR/log.sh"

on_error() {
  local exit_code=$?
  local line_no=${BASH_LINENO[0]:-unknown}
  local src=${BASH_SOURCE[1]:-unknown}
  log_error "installer failed at $(basename "${src}"):${line_no} (exit ${exit_code})"
  log_error "full transcript: ${LOG_FILE}"
  # Flush the tee child before exit; ignore failure on read-only /proc etc.
  sync 2>/dev/null || true
  exit "$exit_code"
}
trap on_error ERR

# shellcheck source=../lib/distro_detect.sh
. "$LIB_DIR/distro_detect.sh"
# shellcheck source=../lib/idempotency.sh
. "$LIB_DIR/idempotency.sh"
# shellcheck source=../lib/as_user.sh
. "$LIB_DIR/as_user.sh"

# Global flag state set by parse_args; main() consults these AFTER require_root
# to branch into run_purge vs the normal provisioner flow.
PURGE_REQUESTED=false
REMOVE_NODEJS_REQUESTED=false

# parse_args — handle flags that either mutate installer state (--verbose,
# --purge, --remove-nodejs) or need the log transcript for diagnostics
# (unknown-flag rejection). Runs after log-init so every message routes
# through the tee.
#
# --help / --version are handled by pre_parse_args above and never reach
# this function; they are kept in this case-match only as a defensive
# fallthrough (should pre_parse_args be refactored).
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s\n' "$AGENTLINUX_VERSION"
        exit 0
        ;;
      --verbose)
        export AGENTLINUX_LOG_LEVEL=DEBUG
        log_debug "verbose logging enabled"
        ;;
      --purge)
        PURGE_REQUESTED=true
        ;;
      --remove-nodejs)
        REMOVE_NODEJS_REQUESTED=true
        ;;
      *)
        log_error "unknown argument: $1"
        usage >&2
        exit 64
        ;;
    esac
    shift
  done
}

require_root() {
  if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
    log_error "agentlinux-install must run as root (EUID != 0). Re-run under sudo."
    exit 64
  fi
}

run_provisioners() {
  local step
  local -a steps
  # `compgen -G` expands the glob via bash's builtin and returns matches on
  # stdout in directory-entry order (NOT guaranteed lexical — on ext4/overlayfs
  # the order depends on inode allocation, so a later-created `30-nodejs.sh`
  # can precede `10-agent-user.sh`). Pipe through `sort` to enforce the
  # numeric-dispatch contract (10 → 30 → 40 → ...). The compgen trailing
  # `|| true` keeps the empty-match case (no provisioner files yet) from
  # tripping `set -e` — caller's length-check below then short-circuits with
  # a warn. Using compgen sidesteps shfmt 3.8.0's lexer misreading
  # `[0-9][0-9]` in an array assignment as an array subscript.
  mapfile -t steps < <(compgen -G "$PROV_DIR/[0-9][0-9]-*.sh" | sort || true)
  if [[ ${#steps[@]} -eq 0 ]]; then
    log_warn "no provisioner scripts found under ${PROV_DIR} (Phase 2 provisioners land in sibling plans)"
    return 0
  fi
  for step in "${steps[@]}"; do
    log_info "running $(basename "$step")"
    # shellcheck disable=SC1090
    . "$step"
  done
}

# run_purge [remove_nodejs_flag]
#
# INST-04 wire-up — replaces the Phase 2 stub. Ordered 7-step teardown; every
# step is idempotent (rm -f no-op on missing, userdel guarded by id check,
# pkill -u guarded by true).
#
# Ordering contract (Pitfall 7 + security-engineer rubric):
#   1. per-agent uninstall.sh (REQUIRES /opt/agentlinux/catalog/ still present)
#   2. rm /opt/agentlinux                          (literal absolute path)
#   3. PATH artefacts (profile.d, agentlinux.env, cron.d)
#   4. NodeSource apt repo files
#   5. (optional) apt-get purge nodejs when $1 == true
#   6. userdel -r agent (pkill first to avoid "user is logged in" refusal)
#   7. LAST — rm /var/log/agentlinux-install.log (the tee is still writing
#      to this file during our run; the EXIT trap at the top of this script
#      closes FD 1+2, delivering EOF to tee. We do the rm LAST so any
#      post-unlink writes land in the unlinked inode that is GC'd after exit.
#      Per Pitfall 7, sequencing log removal LAST avoids mid-invocation FD
#      write-into-/dev/null footguns.)
#
# Security invariants (T-04-16):
#   - Every rm target is a LITERAL absolute path (no $VAR in rm -rf).
#   - Recipe paths derive from $AGENTLINUX_VERSION (controlled by entrypoint,
#     not user input) and the sentinel filename (basename -- NO file-contents
#     grep/eval on agent-writable sentinel JSON).
#   - --remove-nodejs is opt-in (T-04-17); default leaves Node installed.
run_purge() {
  local remove_nodejs=${1:-false}

  log_info "running --purge (destructive)"

  # Step 1: per-agent uninstall.sh for every sentinel.
  # Look up recipe paths from the catalog snapshot keyed by sentinel id —
  # DO NOT trust paths from sentinel JSON contents (a tampered sentinel
  # shouldn't pick arbitrary scripts to execute as agent).
  local state_dir=/opt/agentlinux/state/installed.d
  if [[ -d $state_dir ]]; then
    local f
    for f in "$state_dir"/*.json; do
      [[ -f $f ]] || continue
      local id
      id=$(basename "$f" .json)
      local recipe=/opt/agentlinux/catalog/${AGENTLINUX_VERSION}/agents/${id}/uninstall.sh
      if [[ -x $recipe ]]; then
        log_info "running uninstall.sh for ${id}"
        # as_user's sudo line already appends `--`; passing a second `--`
        # would resolve to `sudo -u agent -H -E -- -- bash <recipe>` and sudo
        # would try to exec `--` ("command not found"). Pass the command
        # verbatim without our own terminator.
        as_user agent bash "$recipe" || log_warn "uninstall.sh for ${id} failed (continuing)"
      else
        log_warn "no uninstall.sh for ${id} at ${recipe}; skipping"
      fi
      rm -f -- "$f"
    done
  fi

  # Step 2: remove /opt/agentlinux (CLI dist, catalog snapshot, state).
  # Literal absolute path — security-engineer rubric flags any $VAR in rm -rf.
  rm -rf /opt/agentlinux/

  # Step 3: PATH artefacts placed by 40-path-wiring.sh.
  rm -f /etc/profile.d/agentlinux.sh
  rm -f /etc/agentlinux.env
  rm -f /etc/cron.d/agentlinux

  # Step 4: NodeSource apt repo files placed by 30-nodejs.sh.
  # Both filenames (deb822 + legacy) handled — setup_22.x may have created
  # either depending on Ubuntu version / prior partial migrations.
  rm -f /etc/apt/sources.list.d/nodesource.sources
  rm -f /etc/apt/sources.list.d/nodesource.list
  rm -f /etc/apt/preferences.d/nodejs

  # Step 5: optionally apt-remove nodejs. Explicit opt-in (T-04-17) — other
  # users on this host may depend on Node installed by this installer.
  if [[ $remove_nodejs == true ]]; then
    log_info "removing nodejs (apt-get purge -y nodejs)"
    DEBIAN_FRONTEND=noninteractive apt-get purge -y nodejs || log_warn "apt purge nodejs failed"
    DEBIAN_FRONTEND=noninteractive apt-get autoremove -y || true
  fi

  # Step 6: remove agent user + /home/agent.
  # pkill -u agent first to avoid "user is logged in" from userdel when an
  # SSH session or systemd-run scope is live. pkill returns non-zero if no
  # matches; that is fine — ignore.
  if id agent >/dev/null 2>&1; then
    pkill -u agent 2>/dev/null || true
    sleep 1
    if ! userdel -r agent 2>/dev/null; then
      log_warn "userdel -r agent failed; trying userdel -rf"
      userdel -rf agent 2>/dev/null || log_error "could not remove agent user"
    fi
  fi

  # Step 7: LAST — remove the install log. See ordering contract above.
  # Pitfall 7 mitigation: sequence LAST so the tee child sees EOF naturally
  # on script exit (EXIT trap closes FDs; unlinked inode is GC'd).
  log_info "--purge complete"
  rm -f /var/log/agentlinux-install.log
}

main() {
  parse_args "$@"
  require_root
  if [[ $PURGE_REQUESTED == true ]]; then
    run_purge "$REMOVE_NODEJS_REQUESTED"
    exit 0
  fi
  log_info "agentlinux-install v${AGENTLINUX_VERSION} starting"
  detect_distro
  run_provisioners
  log_info "agentlinux-install complete (transcript: ${LOG_FILE})"
}

main "$@"
